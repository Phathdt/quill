{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "yarn vite:dev",
    "beforeBuildCommand": "yarn vite:build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "quill",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": false,
        "save": true
      },
      "fs": {
        "all": false,
        "writeFile": true,
        "readFile": true,
        "createDir": true,
        "exists": true,
        "scope": [
          "$DOCUMENT/*",
          "$DOCUMENT/**",
          "$DOWNLOAD/*",
          "$DOWNLOAD/**",
          "$DESKTOP/*",
          "$DESKTOP/**",
          "$HOME/*",
          "$HOME/**",
          "$APPDATA/*",
          "$APPDATA/**",
          "$CONFIG/*",
          "$CONFIG/**",
          "$DATA/*",
          "$DATA/**"
        ]
      },
      "path": {
        "all": true
      }
    },
    "windows": [
      {
        "title": "Quill",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.phathdt.quill",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    }
  }
}
